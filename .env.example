# Copy to .env (git-ignored) and fill in. .env is loaded automatically.
# ntfy topic to notify (subscribe to the same topic in the ntfy app).
NTFY_TOPIC=your-private-topic-name

# Optional overrides:
# NTFY_SERVER=https://ntfy.sh
# R2_BACKSTOP_DATE=2026-07-15
# R2_TIMEZONE=America/Chicago
# R2_HIGH_CONF=0.7
# R2_MAYBE_LOW=0.4
