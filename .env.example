# Copy to .env (git-ignored) and fill in. .env is loaded automatically.
# ntfy topic to notify (subscribe to the same topic in the ntfy app).
NTFY_TOPIC=your-private-topic-name

# Second channel: Slack. Alerts are mirrored here in addition to ntfy.
# Set to your Slack user id (U...) for a DM, or a channel id (C...). The
# scheduled session sends it via the Slack MCP. Leave empty to use ntfy only.
SLACK_USER_ID=

# Optional overrides:
# NTFY_SERVER=https://ntfy.sh
# R2_BACKSTOP_DATE=2026-07-15
# R2_TIMEZONE=America/Chicago
# R2_HIGH_CONF=0.7
# R2_MAYBE_LOW=0.4
